# Frontend (Cloudflare Pages / local Vite)
VITE_API_URL=http://localhost:8787/api

# Worker variables / secrets
# Set GEMINI_API_KEY as a Cloudflare Worker secret, not a committed variable:
#   npm run --prefix worker deploy
#   npx wrangler secret put GEMINI_API_KEY --cwd worker
GEMINI_API_KEY=replace-with-local-dev-key-only
GEMINI_MODEL=gemini-3-flash-preview
ALLOWED_ORIGINS=http://localhost:5173,https://mbr-extractor-frontend.pages.dev
MAX_REQUEST_BYTES=6291456
MAX_IMAGE_BASE64_CHARS=5500000
DEBUG_RAW_MODEL_OUTPUT=false
